<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gateflow.victor.infra.mapper.ConfigVersionMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.gateflow.victor.domain.entity.ConfigVersion">
        <id column="id" property="id"/>
        <result column="version" property="version"/>
        <result column="etag" property="etag"/>
        <result column="config_json" property="configJson"/>
        <result column="change_type" property="changeType"/>
        <result column="changed_experiments" property="changedExperiments"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id
        , version, etag, config_json, change_type, changed_experiments, created_at
    </sql>

    <!-- 查询最新配置版本 -->
    <select id="selectLatestVersion" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM victor_config_version
        ORDER BY created_at DESC
        LIMIT 1
    </select>

    <!-- 查询指定版本之后的变更 -->
    <select id="selectChangesAfterVersion" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM victor_config_version
        WHERE version > #{fromVersion}
        ORDER BY created_at ASC
    </select>

</mapper>
