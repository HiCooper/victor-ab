<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gateflow.victor.infra.mapper.RolePermissionMapper">

    <select id="selectByRoleIds" resultType="com.gateflow.victor.domain.entity.RolePermission">
        SELECT * FROM rbac_role_permission WHERE role_id IN
        <foreach collection="list" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </select>

</mapper>