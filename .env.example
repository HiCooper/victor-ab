# =============================================================================
# GateFlow (Victor) — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================
# Profile: set SPRING_PROFILES_ACTIVE=dev (local) or prod (production)
# =============================================================================

# --- MySQL (required) ---
VICTOR_DB_URL=jdbc:mysql://localhost:3306/victor_experiment?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
VICTOR_DB_USER=root
VICTOR_DB_PASSWORD=

# --- Redis ---
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
# SPRING_DATA_REDIS_DATABASE=0

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# VICTOR_KAFKA_TOPIC=victor-events
# VICTOR_PIPELINE_BATCH_SIZE=100

# --- ClickHouse ---
VICTOR_CLICKHOUSE_URL=jdbc:clickhouse://localhost:8123/victor
VICTOR_CLICKHOUSE_USER=victor
VICTOR_CLICKHOUSE_PASSWORD=

# --- JWT (CRITICAL for production — generate with: openssl rand -base64 64) ---
# Dev only: a fixed key is fine. Production: MUST be a strong random secret.
VICTOR_JWT_SECRET=
# VICTOR_JWT_EXPIRATION=86400000

# --- CORS ---
# Comma-separated allowed origins. Dev default: http://localhost:*
VICTOR_CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Observability (optional) ---
# ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
